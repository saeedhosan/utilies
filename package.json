{
    "name": "utilies",
    "version": "1.3.3",
    "description": "JavaScript utilities for faster development and productivity.",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "type": "module",
    "scripts": {
        "test": "bun test",
        "build": "tsc",
        "rm": "rm -rf ./dist",
        "upload": "tsc && npm publish  --access public"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/saeedhoan/utilies.git"
    },
    "keywords": [
        "utilies",
        "utilities",
        "javascript"
    ],
    "author": "saeedhosan",
    "license": "MIT",
    "files": [
        "dist/"
    ],
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "default": "./dist/index.js",
            "require": "./dist/index.js"
        },
        "./*": {
            "types": "./dist/*.d.ts",
            "import": "./dist/*.js",
            "default": "./dist/*.js",
            "require": "./dist/*.js"
        }
    },
    "devDependencies": {
        "@types/bun": "^1.3.13"
    }
}
